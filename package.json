{
  "name": "vite-plugin-build-console",
  "type": "module",
  "version": "2.0.1",
  "description": "",
  "author": "Abraham K.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/InsHomePgup/vite-plugin-build-console"
  },
  "bugs": "https://github.com/InsHomePgup/vite-plugin-build-console/issues",
  "keywords": [
    "vite",
    "plugin"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "pnpm --filter vue-ts-build dev",
    "build:test": "pnpm --filter vue-ts-build build",
    "build": "unbuild",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "nr build",
    "release:origin": "bumpp && pnpm publish",
    "start": "tsx src/index.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks",
    "commit": "git add . && eslint . --fix && git add . && cz --no-verify",
    "release": "standard-version",
    "release:beta": "standard-version --prerelease beta",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch"
  },
  "dependencies": {
    "@types/adm-zip": "^0.5.7",
    "adm-zip": "^0.5.16",
    "boxen": "^8.0.1",
    "bytes-formatter": "^21.6.15",
    "dayjs": "^1.11.19",
    "get-folder-size": "^5.0.0",
    "gradient-string": "^3.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.6.1",
    "@antfu/ni": "^28.0.0",
    "@antfu/utils": "^9.3.0",
    "@types/node": "^24.1.0",
    "@vitejs/plugin-legacy": "7.2.1",
    "bumpp": "^10.3.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.1",
    "lint-staged": "^16.2.7",
    "pnpm": "^10.25.0",
    "simple-git-hooks": "^2.13.1",
    "standard-version": "^9.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vite": "7.2.7",
    "vitest": "^3.2.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint . --fix"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
