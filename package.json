{
  "name": "vite-plugin-build-console",
  "type": "module",
  "version": "2.0.1",
  "description": "",
  "author": "Abraham K.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/InsHomePgup/vite-plugin-build-console"
  },
  "bugs": "https://github.com/InsHomePgup/vite-plugin-build-console/issues",
  "keywords": [
    "vite",
    "plugin"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "pnpm --filter vue-ts-build dev",
    "build:test": "pnpm --filter vue-ts-build build",
    "build": "unbuild",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "nr build",
    "release:origin": "bumpp && pnpm publish",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks",
    "commit": "git add . && eslint . --fix && git add . && czg --no-verify",
    "release": "release-it",
    "release:beta": "release-it --preRelease=beta",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "release:patch": "release-it patch"
  },
  "dependencies": {
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "boxen": "^8.0.1",
    "bytes-formatter": "^21.6.15",
    "dayjs": "^1.11.20",
    "get-folder-size": "^5.0.0",
    "gradient-string": "^3.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.6.1",
    "@antfu/ni": "^30.0.0",
    "@antfu/utils": "^9.3.0",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/node": "^24.1.0",
    "bumpp": "^11.0.0",
    "czg": "^1.13.1",
    "eslint": "^9.39.1",
    "lint-staged": "^17.0.0",
    "pnpm": "^10.28.2",
    "release-it": "^20.0.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vite": "^7.3.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint . --fix"
  },
  "czg": {
    "emoji": true,
    "scopes": []
  }
}
